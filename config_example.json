{
  "source_url": "https://nextcloud-url.cm/2sWLBzk",
  "source_subdir": "/C",
  "source_type": "nextcloud",
  "target_dir": "C:/Synced/target_folder",
  "password": "",
  "retries": 3,
  "timeout": 30,
  "log_level": "INFO",
  "pipelines": [
    {
      "pattern": "\\.webm$",
      "delete_original": false,
      "commands": [
        "ffmpeg -i {file} -c:v libx264 {file_stem}.mp4",
        "python some_tool.py --input {file_stem}.mp4"
      ]
    },
    {
      "pattern": "\\.mp4$",
      "commands": [
        "python some_tool.py --input {file}"
      ]
    }
  ],
  "routes": [
    {"pattern": "\\.mp3$", "target_dir": "../../Assets/Audio"},
    {"pattern": "\\.webm$", "target_dir": "D:/Unity3D/project/Assets/Videos"},
    {"pattern": "\\.mp4$", "target_dir": "../../Assets/StreamingAssets"}
  ],
  "post_sync": [
    "python rebuild_index.py --dir {target_dir}",
    "echo Sync complete"
  ]
}
